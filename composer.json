{
    "name": "maslennikov-yv/action-generator",
    "type": "library",
    "require": {
        "php": "^8.1",
        "illuminate/console": "^10.0|^11.0|^12.0",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "spatie/laravel-data": "^4.11"
    },
    "autoload": {
        "psr-4": {
            "Maslennikov\\LaravelActions\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maslennikov\\LaravelActions\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^10.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maslennikov\\LaravelActions\\LaravelActionsServiceProvider"
            ]
        }
    },
    "authors": [
        {
            "name": "Yuriy Maslennikov",
            "email": "masslennikovyv@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
